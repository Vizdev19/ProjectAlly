NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — for sending invite emails (https://resend.com)
RESEND_API_KEY=
# Optional: override the From address. Defaults to onboarding@resend.dev,
# which works out of the box on any Resend account for testing. For
# production, verify your own domain and set e.g.
#   "AllyTracker <invites@your-domain.com>"
RESEND_FROM=

# Optional: GitHub token for /download page release lookups.
# Without it, GitHub's API rate-limits at 60 req/hr per IP — easy to
# exhaust on shared Vercel infra. A fine-grained PAT scoped to the
# Vizdev19/ProjectAlly repo (contents:read) is enough.
GITHUB_API_TOKEN=
