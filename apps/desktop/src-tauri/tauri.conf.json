{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AllyTracker",
  "version": "0.1.4",
  "identifier": "com.allytracker.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AllyTracker",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "AllyTracker",
    "copyright": "© 2026 AllyTracker"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Vizdev19/ProjectAlly/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2Q0E0M0Y5MzM2MkY2OEYKUldTUDltSXorVVBLWms3WEhJNFBweU5iYkpiNUNIMlVUWXBITFJ2VUNEZGkxbHNYUGNvd0doU3IK"
    },
    "autostart": {
      "args": ["--minimized"]
    }
  }
}
