{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AllyTracker",
  "version": "0.1.0",
  "identifier": "com.allytracker.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AllyTracker",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "publisher": "AllyTracker",
    "copyright": "© 2026 AllyTracker"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/YOUR_ORG/ally-tracker/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": ""
    },
    "autostart": {
      "args": ["--minimized"]
    }
  }
}
