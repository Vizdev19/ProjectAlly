{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability granted to the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:path:default",
    "updater:default",
    "process:default",
    "notification:default",
    "autostart:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" }
      ]
    }
  ]
}
